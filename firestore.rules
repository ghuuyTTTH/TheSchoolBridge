rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'createdAt']) &&
             data.id == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['student', 'teacher', 'parent'] &&
             data.createdAt is number;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['id', 'teacherId', 'classCode', 'className', 'createdAt', 'studentIds', 'pendingIds']) &&
             data.id is string && data.id.size() <= 128 &&
             data.teacherId == request.auth.uid &&
             data.classCode is string && data.classCode.size() <= 20 &&
             data.className is string && data.className.size() <= 100 &&
             data.createdAt is number &&
             data.studentIds is list &&
             data.pendingIds is list;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // For finding teachers/students
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role; // Role is immutable
    }

    match /classes/{classId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && isValidClass(incoming());
      allow update: if isSignedIn() && (
        // Action: Teacher updates class
        (existing().teacherId == request.auth.uid && isValidClass(incoming())) ||
        // Action: Student joins (adds self to studentIds or pendingIds)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['studentIds', 'pendingIds']) &&
          (
            (incoming().studentIds.size() == existing().studentIds.size() + 1 && incoming().studentIds.hasAll(existing().studentIds) && (incoming().studentIds[(incoming().studentIds.size() - 1)] == request.auth.uid)) ||
            (incoming().pendingIds.size() == existing().pendingIds.size() + 1 && incoming().pendingIds.hasAll(existing().pendingIds) && (incoming().pendingIds[(incoming().pendingIds.size() - 1)] == request.auth.uid))
          )
        )
      );
      allow delete: if isSignedIn() && existing().teacherId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && existing().receiverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }

    match /helpRequests/{requestId} {
      allow read: if isSignedIn() && (existing().studentId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update: if isSignedIn() && (existing().studentId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    match /moodLogs/{logId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'parent']);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && existing().to == request.auth.uid;
      allow create: if isSignedIn(); // System/Teacher can create
      allow update: if isSignedIn() && existing().to == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().to == request.auth.uid;
    }

    match /studentProgress/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(userId) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }
  }
}
